{
  "$schema": "https://schemas.elgato.com/streamdeck/plugins/manifest.json",
  "Name": "Deck Threads",
  "Version": "1.0.2.0",
  "Author": "rschwabco",
  "Actions": [
    {
      "Name": "Task slot",
      "UUID": "com.roie.deck-threads.thread",
      "Icon": "imgs/actions/thread/icon",
      "Tooltip": "Shows a live Codex or Claude task and opens it when pressed.",
      "PropertyInspectorPath": "ui/property-inspector.html",
      "Controllers": [
        "Keypad"
      ],
      "UserTitleEnabled": false,
      "States": [
        {
          "Image": "imgs/actions/thread/key",
          "ShowTitle": false
        }
      ]
    }
  ],
  "Category": "Deck Threads",
  "CategoryIcon": "imgs/plugin/category-icon",
  "CodePath": "bin/plugin.js",
  "Description": "Unofficial local companion for showing live Codex and Claude tasks on Stream Deck and opening them with one press.",
  "Icon": "imgs/plugin/marketplace",
  "SDKVersion": 3,
  "Software": {
    "MinimumVersion": "7.1"
  },
  "OS": [
    {
      "Platform": "mac",
      "MinimumVersion": "13"
    }
  ],
  "Nodejs": {
    "Version": "20"
  },
  "UUID": "com.roie.deck-threads",
  "Profiles": [
    {
      "Name": "deck-threads",
      "DeviceType": 7,
      "AutoInstall": true,
      "DontAutoSwitchWhenInstalled": false,
      "Readonly": false
    }
  ]
}
