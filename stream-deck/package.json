{
  "name": "deck-threads-stream-deck",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:profile": "node scripts/build-profile.mjs",
    "build": "npm run build:profile && rollup -c",
    "validate": "streamdeck validate com.roie.deck-threads.sdPlugin",
    "link": "npm run build && streamdeck link com.roie.deck-threads.sdPlugin",
    "restart": "streamdeck restart com.roie.deck-threads",
    "pack": "npm run build && streamdeck pack com.roie.deck-threads.sdPlugin --force"
  },
  "dependencies": {
    "@elgato/streamdeck": "^2.0.1"
  },
  "devDependencies": {
    "@elgato/cli": "^1.7.0",
    "@rollup/plugin-commonjs": "^28.0.2",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-typescript": "^12.1.2",
    "@tsconfig/node20": "^20.1.4",
    "@types/node": "^22.13.0",
    "rollup": "^4.32.1",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3"
  }
}
